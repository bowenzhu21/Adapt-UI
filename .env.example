# Required
OPENAI_API_KEY=sk-your-openai-key

# Optional: override OpenAI chat endpoint
# OPENAI_CHAT_API_URL=https://api.openai.com/v1/chat/completions

# Optional: request and caching controls
# OPENAI_TIMEOUT_MS=25000
# OPENAI_MAX_RETRIES=2
# OPENAI_MAX_INPUT_CHARS=20000
# OPENAI_MAX_OUTPUT_TOKENS=3000
# OPENAI_CACHE_ENABLED=true
# OPENAI_CACHE_TTL_SECONDS=3600

# Optional: model selection
# OPENAI_GENERATION_MODEL=gpt-4o-mini
# OPENAI_GENERATION_MODEL_COMPLEX=gpt-4o-mini
# OPENAI_GENERATION_MODEL_GAME=gpt-4o
# OPENAI_REPAIR_MODEL=gpt-4o-mini
# OPENAI_REPAIR_MODEL_GAME=gpt-4o
# OPENAI_DEBUG_MODEL=gpt-4o-mini
# OPENAI_DEBUG_MODEL_GAME=gpt-4o
# OPENAI_PLAN_MODEL=gpt-4o-mini
# OPENAI_VALIDATION_MODEL=gpt-4o-mini

# Optional: quality and token budgets
# OPENAI_MAX_PROMPT_CHARS=900
# OPENAI_GENERATION_MAX_TOKENS=1400
# OPENAI_GENERATION_MAX_TOKENS_COMPLEX=2800
# OPENAI_GENERATION_MAX_TOKENS_GAME=3800
# OPENAI_DEBUG_MAX_TOKENS=1200
# OPENAI_DEBUG_MAX_TOKENS_GAME=1650
# OPENAI_SERVER_REPAIR_PASSES=1
# OPENAI_SERVER_REPAIR_PASSES_GAME=2
# OPENAI_MIN_QUALITY_SCORE=0.62
# OPENAI_MIN_GAME_QUALITY_SCORE=0.74
# OPENAI_GENERATION_ENABLE_PLANNER=true
# OPENAI_ENABLE_AI_VALIDATION=false

# Optional: local bundle analyzer
# ANALYZE=false
